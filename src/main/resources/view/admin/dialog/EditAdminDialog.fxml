<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="root" spacing="0" styleClass="dialog-root" stylesheets="@/styles/admin/dialog/editadmindialog.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ionres.respondph.admin.dialogs_controller.EditAdminDialogController">

    <!-- ==================== HEADER SECTION ==================== -->
    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="dialog-header">
        <padding>
            <Insets bottom="18" left="24" right="24" top="18" />
        </padding>
        <FontAwesomeIconView glyphName="EDIT" size="22" styleClass="header-icon" />
        <VBox spacing="2">
            <Label styleClass="dialog-title" text="Edit Administrator" />
            <Label styleClass="dialog-subtitle" text="Update administrator details. Fields marked with * are required." />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="closeButton" styleClass="dialog-close">
            <graphic>
                <HBox alignment="CENTER" spacing="8">
                    <FontAwesomeIconView glyphName="TIMES" size="14" styleClass="close-icon" />
                </HBox>
            </graphic>
        </Button>
    </HBox>

    <!-- ==================== ERROR CONTAINER ==================== -->
    <VBox alignment="CENTER" managed="false" styleClass="error-box" visible="false">
        <padding>
            <Insets bottom="12" left="24" right="24" top="10" />
        </padding>
        <Label fx:id="errorLabel" styleClass="error-text" />
    </VBox>

    <!-- ==================== SCROLLABLE FORM ==================== -->
    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                styleClass="dialog-scroll"
                VBox.vgrow="ALWAYS"
                maxHeight="520"
                minHeight="200">

        <VBox spacing="24" styleClass="dialog-body">
            <padding>
                <Insets bottom="24" left="24" right="24" top="20" />
            </padding>

            <!-- ==================== SECTION 1: ACCOUNT INFORMATION ==================== -->
            <VBox spacing="18" styleClass="form-section">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="USER_SECRET" size="18" styleClass="section-icon" />
                    <Label styleClass="section-title" text="Account Information" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="section-subtitle" text="Step 1 of 3" />
                </HBox>

                <!-- Username -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Username *" />
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="flat-input">
                        <FontAwesomeIconView glyphName="USER" size="14" styleClass="field-icon" />
                        <TextField fx:id="usernameField" promptText="Enter username"
                                   styleClass="field-input" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>

                <!-- Info Box -->
                <VBox spacing="6" styleClass="info-box">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <FontAwesomeIconView glyphName="INFO_CIRCLE" size="14" styleClass="info-icon" />
                        <Label styleClass="info-title" text="Username Information" />
                    </HBox>
                    <Label styleClass="info-text" text="• Username must be unique across all administrators" />
                </VBox>
            </VBox>

            <Separator />

            <!-- ==================== SECTION 2: PERSONAL INFORMATION ==================== -->
            <VBox spacing="18" styleClass="form-section">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="ID_CARD" size="18" styleClass="section-icon" />
                    <Label styleClass="section-title" text="Personal Information" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="section-subtitle" text="Step 2 of 3" />
                </HBox>

                <!-- Name Fields -->
                <GridPane hgap="16" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="40" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="30" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="30" />
                    </columnConstraints>
                    <rowConstraints><RowConstraints /></rowConstraints>

                    <VBox spacing="8" GridPane.columnIndex="0">
                        <Label styleClass="field-label" text="First Name *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="USER" size="14" styleClass="field-icon" />
                            <TextField fx:id="firstNameField" promptText="Enter first name"
                                       styleClass="field-input" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="1">
                        <Label styleClass="field-label" text="Middle Name" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="USER" size="14" styleClass="field-icon" />
                            <TextField fx:id="middleNameField" promptText="Middle name"
                                       styleClass="field-input" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="2">
                        <Label styleClass="field-label" text="Last Name *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="USER" size="14" styleClass="field-icon" />
                            <TextField fx:id="lastNameField" promptText="Last name"
                                       styleClass="field-input" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                </GridPane>
            </VBox>

            <Separator />

            <!-- ==================== SECTION 3: ROLE ASSIGNMENT ==================== -->
            <VBox spacing="18" styleClass="form-section">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="SHIELD" size="18" styleClass="section-icon" />
                    <Label styleClass="section-title" text="Role Assignment" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="section-subtitle" text="Step 3 of 3" />
                </HBox>

                <!-- Role ComboBox -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Role *" />
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="flat-input">
                        <FontAwesomeIconView glyphName="ID_BADGE" size="14" styleClass="field-icon" />
                        <ComboBox fx:id="roleComboBox"
                                  promptText="Select a role"
                                  styleClass="field-input"
                                  HBox.hgrow="ALWAYS"
                                  maxWidth="1.7976931348623157E308" />
                    </HBox>
                </VBox>

                <!-- Role Info -->
                <VBox spacing="6" styleClass="info-box">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <FontAwesomeIconView glyphName="INFO_CIRCLE" size="14" styleClass="info-icon" />
                        <Label styleClass="info-title" text="Role Permissions" />
                    </HBox>
                    <Label styleClass="info-text" text="• Admin — Full access to all features" />
                    <Label styleClass="info-text" text="• Brgy_Sec — Management section only" />
                    <Label styleClass="info-text" text="• MSWDO — Aids Management + Management" />
                    <Label styleClass="info-text" text="• LDRRMO — Disaster + Evacuation Site + Dashboard" />
                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- ==================== FOOTER SECTION ==================== -->
    <HBox alignment="CENTER_RIGHT" spacing="14" styleClass="dialog-footer">
        <padding>
            <Insets bottom="20" left="24" right="24" top="20" />
        </padding>
        <Button fx:id="updateBtn" prefHeight="42.0" prefWidth="160.0" styleClass="btn-primary">
            <graphic>
                <HBox alignment="CENTER" spacing="10">
                    <FontAwesomeIconView glyphName="CHECK" size="16" styleClass="btn-icon" />
                    <Label styleClass="btn-text" text="Update Admin" />
                </HBox>
            </graphic>
        </Button>
    </HBox>

</VBox>