<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="root" prefHeight="900.0" prefWidth="1000.0" spacing="0" styleClass="dialog-root" stylesheets="@/styles/aid/dialog/previewdistributiondialog.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ionres.respondph.aid.dialogs_controller.PreviewDistributionController">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  HEADER                                                     -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="dialog-header">
        <padding>
            <Insets bottom="18" left="24" right="24" top="18" />
        </padding>

        <FontAwesomeIconView glyphName="USERS" size="22" styleClass="header-icon" />

        <VBox spacing="2">
            <Label styleClass="dialog-title" text="Preview Distribution" />
            <Label styleClass="dialog-subtitle" text="Beneficiary priority clustering result — 3 clusters" />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <Button fx:id="closeBtn" mnemonicParsing="false" styleClass="dialog-close">
            <graphic>
                <HBox alignment="CENTER" spacing="8">
                    <FontAwesomeIconView glyphName="TIMES" size="14" styleClass="close-icon" />
                </HBox>
            </graphic>
        </Button>
    </HBox>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  SCROLLABLE BODY                                            -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <ScrollPane fitToWidth="true" styleClass="dialog-scroll" VBox.vgrow="ALWAYS">

        <VBox spacing="16" styleClass="dialog-body">
            <padding>
                <Insets bottom="20" left="24" right="24" top="20" />
            </padding>

            <!-- Meta info row -->
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="meta-row">

                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="meta-chip">
                    <FontAwesomeIconView glyphName="GLOBE" size="12" styleClass="meta-chip-icon" />
                    <Label styleClass="meta-chip-key" text="Scope:" />
                    <Label fx:id="scopeLabel" styleClass="meta-chip-value" text="—" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="meta-chip">
                    <FontAwesomeIconView glyphName="COG" size="12" styleClass="meta-chip-icon" />
                    <Label styleClass="meta-chip-key" text="Method:" />
                    <Label fx:id="methodLabel" styleClass="meta-chip-value" text="—" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="meta-chip">
                    <FontAwesomeIconView glyphName="USER" size="12" styleClass="meta-chip-icon" />
                    <Label styleClass="meta-chip-key" text="Total:" />
                    <Label fx:id="totalLabel" styleClass="meta-chip-value" text="0 beneficiaries" />
                </HBox>

                <Region HBox.hgrow="ALWAYS" />
            </HBox>

            <!-- ── HIGH PRIORITY ─────────────────────────────── -->
            <VBox spacing="0" styleClass="form-section table-section">

                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="ARROW_UP" size="13" styleClass="section-icon-high" />
                    <Label styleClass="section-title" text="HIGH PRIORITY" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="highCountBadge" styleClass="section-badge section-badge-high" text="0" />
                    <Label fx:id="highAvgLabel" styleClass="section-avg" text="Avg: —" />
                </HBox>

                <TableView fx:id="highPriorityTable" prefHeight="320.0" styleClass="priority-table">
                    <columns>
                        <TableColumn fx:id="highRankCol" maxWidth="100" minWidth="100" text="#" />
                        <TableColumn fx:id="highIdCol" maxWidth="100" minWidth="100" text="ID" />
                        <TableColumn fx:id="highNameCol" prefWidth="1" text="Name" />
                        <TableColumn fx:id="highScoreCol" maxWidth="100" minWidth="100" text="Score" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

            </VBox>

            <!-- ── MODERATE PRIORITY ─────────────────────────── -->
            <VBox spacing="0" styleClass="form-section table-section">

                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="MINUS" size="13" styleClass="section-icon-moderate" />
                    <Label styleClass="section-title" text="MODERATE PRIORITY" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="moderateCountBadge" styleClass="section-badge section-badge-moderate" text="0" />
                    <Label fx:id="moderateAvgLabel" styleClass="section-avg" text="Avg: —" />
                </HBox>

                <TableView fx:id="moderatePriorityTable" prefHeight="320.0" styleClass="priority-table">
                    <columns>
                        <TableColumn fx:id="modRankCol" maxWidth="100" minWidth="100" text="#" />
                        <TableColumn fx:id="modIdCol" maxWidth="100" minWidth="100" text="ID" />
                        <TableColumn fx:id="modNameCol" prefWidth="1" text="Name" />
                        <TableColumn fx:id="modScoreCol" maxWidth="100" minWidth="100" text="Score" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

            </VBox>

            <!-- ── LOW PRIORITY ──────────────────────────────── -->
            <VBox spacing="0" styleClass="form-section table-section">

                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="ARROW_DOWN" size="13" styleClass="section-icon-low" />
                    <Label styleClass="section-title" text="LOW PRIORITY" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lowCountBadge" styleClass="section-badge section-badge-low" text="0" />
                    <Label fx:id="lowAvgLabel" styleClass="section-avg" text="Avg: —" />
                </HBox>

                <TableView fx:id="lowPriorityTable" prefHeight="320.0" styleClass="priority-table">
                    <columns>
                        <TableColumn fx:id="lowRankCol" maxWidth="100" minWidth="100" text="#" />
                        <TableColumn fx:id="lowIdCol" maxWidth="100" minWidth="100" text="ID" />
                        <TableColumn fx:id="lowNameCol" prefWidth="1" text="Name" />
                        <TableColumn fx:id="lowScoreCol" maxWidth="100" minWidth="100" text="Score" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

            </VBox>

            <!-- Bottom breathing room -->
            <VBox minHeight="8" />

        </VBox>

    </ScrollPane>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  FOOTER                                                     -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_RIGHT" spacing="14" styleClass="dialog-footer">
        <padding>
            <Insets bottom="20" left="24" right="24" top="20" />
        </padding>

    </HBox>

</VBox>
