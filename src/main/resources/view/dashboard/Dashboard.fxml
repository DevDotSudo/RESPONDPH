<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.ionres.respondph.dashboard.DashboardController"
           styleClass="dashboard-root"
           stylesheets="@/styles/dashboard/dashboard.css">

    <!-- ── Main content ───────────────────────────────────────────────────── -->
    <VBox spacing="15.0" styleClass="dashboard-wrapper">

        <!--
            viewOrder="-1" makes this topbar render ABOVE the modal overlay
            (lower viewOrder = painted last = on top in JavaFX).
        -->
        <HBox alignment="CENTER_LEFT" styleClass="dashboard-topbar" viewOrder="-1">
            <Label styleClass="dashboard-topbar-title" text="Dashboard Mapping" />

            <Region HBox.hgrow="ALWAYS" />

            <VBox alignment="CENTER" spacing="4" styleClass="clock-container">
                <Label fx:id="currentTimeLabel" styleClass="clock-time" />
                <Label fx:id="currentDateLabel" styleClass="clock-date" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />


            <!-- Admin area -->
            <StackPane fx:id="adminAreaPane" alignment="TOP_RIGHT" styleClass="admin-area-pane">

                <HBox fx:id="adminNameLabel" alignment="CENTER_RIGHT" spacing="8"
                      styleClass="admin-name-label">
                    <FontAwesomeIconView glyphName="USER_CIRCLE" styleClass="admin-icon-inside" />
                    <Label fx:id="adminNameText" text="Admin Name" mouseTransparent="true" />
                    <FontAwesomeIconView glyphName="CHEVRON_DOWN" styleClass="admin-chevron"
                                         mouseTransparent="true" />
                </HBox>

                <!-- Dropdown (hidden by default) -->
                <VBox fx:id="adminDropdown"
                      styleClass="admin-dropdown"
                      visible="false"
                      managed="false"
                      StackPane.alignment="BOTTOM_RIGHT"
                      translateY="40">

                    <HBox fx:id="changePasswordMenuItem"
                          styleClass="admin-dropdown-item"
                          alignment="CENTER_LEFT"
                          spacing="10">
                        <FontAwesomeIconView glyphName="KEY" styleClass="admin-dropdown-icon"
                                             mouseTransparent="true" />
                        <Label text="Change Password" styleClass="admin-dropdown-label"
                               mouseTransparent="true" />
                    </HBox>

                </VBox>
            </StackPane>

        </HBox>

        <!--
            viewOrder="-1" keeps the cards row above the modal overlay too.
        -->
        <GridPane hgap="16" styleClass="cards-grid" vgap="16" viewOrder="-1">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <StackPane fx:id="cardBeneficiary" styleClass="flat-card-blue" GridPane.columnIndex="0">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="flat-card-content">
                    <StackPane styleClass="flat-icon">
                        <FontAwesomeIconView glyphName="USERS" styleClass="flat-icon-symbol" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="totalBeneficiaryLabel" styleClass="flat-value" text="0" />
                        <Label styleClass="flat-label" text="Beneficiaries" />
                    </VBox>
                </HBox>
            </StackPane>

            <StackPane fx:id="cardDisasters" styleClass="flat-card-red" GridPane.columnIndex="1">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="flat-card-content">
                    <StackPane styleClass="flat-icon">
                        <FontAwesomeIconView glyphName="EXCLAMATION_TRIANGLE" styleClass="flat-icon-symbol" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="totalDisastersLabel" styleClass="flat-value" text="0" />
                        <Label styleClass="flat-label" text="Disasters" />
                    </VBox>
                </HBox>
            </StackPane>

            <StackPane fx:id="cardAids" styleClass="flat-card-green" GridPane.columnIndex="2">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="flat-card-content">
                    <StackPane styleClass="flat-icon">
                        <FontAwesomeIconView glyphName="MEDKIT" styleClass="flat-icon-symbol" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="totalAidsLabel" styleClass="flat-value" text="0" />
                        <Label styleClass="flat-label" text="Aids" />
                    </VBox>
                </HBox>
            </StackPane>

            <StackPane fx:id="cardEvacuationSite" styleClass="flat-card-yellow" GridPane.columnIndex="3">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="flat-card-content">
                    <StackPane styleClass="flat-icon">
                        <FontAwesomeIconView glyphName="HOME" styleClass="flat-icon-symbol" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="totalEvacutaionSiteLabel" styleClass="flat-value" text="0" />
                        <Label styleClass="flat-label" text="Evacuation Site" />
                    </VBox>
                </HBox>
            </StackPane>

            <rowConstraints>
                <RowConstraints />
            </rowConstraints>
        </GridPane>

        <StackPane VBox.vgrow="ALWAYS" styleClass="map-wrapper">
            <Pane fx:id="mapContainer" styleClass="map-container" StackPane.alignment="CENTER" />

            <HBox fx:id="searchOverlay"
                  alignment="TOP_RIGHT"
                  spacing="8"
                  styleClass="map-search-overlay"
                  StackPane.alignment="TOP_RIGHT"
                  pickOnBounds="false">

                <VBox fx:id="searchBoxWrap"
                      spacing="0"
                      alignment="TOP_RIGHT"
                      pickOnBounds="false"
                      managed="false"
                      visible="false"
                      VBox.vgrow="NEVER">
                    <TextField fx:id="beneficiarySearchBox"
                               promptText="Find beneficiary."
                               styleClass="map-search-combobox"
                               visible="true"
                               managed="true" />
                    <ListView fx:id="beneficiarySearchList"
                              prefWidth="280"
                              styleClass="search-popup-list"
                              managed="false"
                              visible="false"
                              VBox.vgrow="NEVER" />
                </VBox>

                <VBox alignment="TOP_CENTER" HBox.hgrow="NEVER">
                    <Button fx:id="searchToggleBtn" styleClass="map-search-btn">
                        <graphic>
                            <FontAwesomeIconView glyphName="SEARCH" styleClass="map-search-icon" />
                        </graphic>
                    </Button>
                </VBox>
            </HBox>
        </StackPane>

    </VBox>

    <!--
        Modal overlay — child of ROOT StackPane so it truly centers over the
        entire dashboard. viewOrder="0" (default) places it between the main
        VBox (viewOrder default 0 for children) and the topbar/cards which are
        set to viewOrder="-1" so they paint on top and stay visible.
    -->
    <StackPane fx:id="changePasswordOverlay"
               styleClass="modal-overlay"
               visible="false"
               managed="false"
               pickOnBounds="true">

        <VBox fx:id="changePasswordDialog"
              styleClass="change-password-dialog"
              maxWidth="380"
              maxHeight="-Infinity"
              spacing="0">

            <!-- Header -->
            <HBox styleClass="cpd-header" alignment="CENTER_LEFT">
                <StackPane styleClass="cpd-header-icon">
                    <FontAwesomeIconView glyphName="LOCK" styleClass="cpd-header-icon-glyph" />
                </StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Change Password" styleClass="cpd-title" />
                    <Label text="Update your account credentials" styleClass="cpd-subtitle" />
                </VBox>
                <Button fx:id="closePasswordDialogBtn" styleClass="cpd-close-btn" text="×" />
            </HBox>

            <Region styleClass="cpd-divider" prefHeight="1" />

            <!-- Body -->
            <VBox styleClass="cpd-body" spacing="16">

                <VBox spacing="6">
                    <Label text="Current Password" styleClass="cpd-field-label" />
                    <HBox fx:id="currentPwRow" styleClass="cpd-input-wrap" alignment="CENTER_LEFT">
                        <FontAwesomeIconView glyphName="KEY" styleClass="cpd-input-icon" />
                        <PasswordField fx:id="currentPasswordField"
                                       promptText="Enter current password"
                                       styleClass="cpd-input"
                                       HBox.hgrow="ALWAYS" />
                        <Button fx:id="toggleCurrentPwBtn" styleClass="cpd-eye-btn" text="👁" />
                    </HBox>
                </VBox>

                <Region styleClass="cpd-field-divider" prefHeight="1" />

                <VBox spacing="6">
                    <Label text="New Password" styleClass="cpd-field-label" />
                    <HBox fx:id="newPwRow" styleClass="cpd-input-wrap" alignment="CENTER_LEFT">
                        <FontAwesomeIconView glyphName="LOCK" styleClass="cpd-input-icon" />
                        <PasswordField fx:id="newPasswordField"
                                       promptText="Enter new password"
                                       styleClass="cpd-input"
                                       HBox.hgrow="ALWAYS" />
                        <Button fx:id="toggleNewPwBtn" styleClass="cpd-eye-btn" text="👁" />
                    </HBox>
                </VBox>

                <VBox spacing="6">
                    <Label text="Confirm New Password" styleClass="cpd-field-label" />
                    <HBox fx:id="confirmPwRow" styleClass="cpd-input-wrap" alignment="CENTER_LEFT">
                        <FontAwesomeIconView glyphName="CHECK_CIRCLE" styleClass="cpd-input-icon" />
                        <PasswordField fx:id="confirmPasswordField"
                                       promptText="Re-enter new password"
                                       styleClass="cpd-input"
                                       HBox.hgrow="ALWAYS" />
                        <Button fx:id="toggleConfirmPwBtn" styleClass="cpd-eye-btn" text="👁" />
                    </HBox>
                </VBox>

                <Label fx:id="passwordMessageLabel"
                       styleClass="cpd-message-label"
                       managed="false"
                       visible="false"
                       wrapText="true" />

            </VBox>

            <Region styleClass="cpd-divider" prefHeight="1" />

            <!-- Footer -->
            <HBox styleClass="cpd-footer" spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="cancelPasswordBtn" styleClass="cpd-cancel-btn" text="Cancel" />
                <Button fx:id="confirmPasswordBtn" styleClass="cpd-confirm-btn">
                    <graphic>
                        <HBox spacing="6" alignment="CENTER">
                            <FontAwesomeIconView glyphName="SAVE" styleClass="cpd-confirm-icon" />
                            <Label text="Update Password" styleClass="cpd-confirm-label"
                                   mouseTransparent="true" />
                        </HBox>
                    </graphic>
                </Button>
            </HBox>

        </VBox>
    </StackPane>

</StackPane>
