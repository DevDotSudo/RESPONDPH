<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="root" spacing="0" styleClass="polygon-dialog-root" stylesheets="@/styles/disaster/dialog/polygon_mapping.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ionres.respondph.disaster.dialogs_controller.PolygonMappingController">

    <!-- ==================== HEADER ==================== -->
    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="dialog-header">
        <padding>
            <Insets bottom="16" left="22" right="22" top="16" />
        </padding>

        <FontAwesomeIconView glyphName="MAP_MARKER" size="20" styleClass="header-icon" />
        <VBox spacing="2">
            <Label styleClass="dialog-title" text="Select Polygon Points" />
            <Label styleClass="dialog-subtitle" text="Click on the map to add boundary points. At least 3 points required." />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <!-- Point counter badge -->
        <HBox alignment="CENTER" spacing="6" styleClass="point-counter-box">
            <FontAwesomeIconView glyphName="MAP_PIN" size="12" styleClass="counter-icon" />
            <Label fx:id="pointCounterLabel" styleClass="counter-label" text="0 points" />
        </HBox>

        <Button fx:id="exitBtn" styleClass="dialog-close">
            <graphic>
                <HBox alignment="CENTER">
                    <FontAwesomeIconView glyphName="TIMES" size="13" styleClass="close-icon" />
                </HBox>
            </graphic>
        </Button>
    </HBox>

    <!-- ==================== BODY: LEFT LIST + RIGHT MAP ==================== -->
    <HBox spacing="0" VBox.vgrow="ALWAYS">

        <!-- ===== LEFT PANEL: POINT LIST ===== -->
        <VBox maxWidth="260" minWidth="260" prefWidth="260" spacing="0" styleClass="left-panel">

            <!-- Panel Header -->
            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="panel-header">
                <padding>
                    <Insets bottom="12" left="16" right="16" top="12" />
                </padding>
                <FontAwesomeIconView glyphName="LIST_OL" size="13" styleClass="panel-header-icon" />
                <Label styleClass="panel-header-label" text="Selected Points" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="clearAllBtn" styleClass="clear-all-btn">
                    <graphic>
                        <HBox alignment="CENTER" spacing="5">
                            <FontAwesomeIconView glyphName="TRASH" size="11" styleClass="clear-all-icon" />
                            <Label styleClass="clear-all-text" text="Clear All" />
                        </HBox>
                    </graphic>
                </Button>
            </HBox>

            <Separator styleClass="panel-separator" />

            <!-- Empty state -->
            <VBox fx:id="listEmptyState" alignment="CENTER" spacing="10" styleClass="list-empty-state" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="24" left="16" right="16" top="24" />
                </padding>
                <FontAwesomeIconView glyphName="HAND_O_UP" size="30" styleClass="empty-icon" />
                <Label styleClass="empty-title" text="No Points Yet" />
                <Label styleClass="empty-desc" text="Click anywhere on the map to start adding boundary points." wrapText="true" />
            </VBox>

            <!-- Points scroll list -->
            <ScrollPane fx:id="pointsScrollPane" fitToWidth="true" managed="false" styleClass="points-scroll" visible="false" VBox.vgrow="ALWAYS">
                <VBox fx:id="pointsListContainer" spacing="0" styleClass="points-list" />
            </ScrollPane>

            <!-- Bottom info bar -->
            <VBox styleClass="list-footer">
                <padding>
                    <Insets bottom="12" left="14" right="14" top="10" />
                </padding>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <FontAwesomeIconView glyphName="INFO_CIRCLE" size="11" styleClass="footer-info-icon" />
                    <Label styleClass="footer-info-text" text="Points connect in order to form the polygon." wrapText="true" />
                </HBox>
            </VBox>
        </VBox>

        <!-- ===== VERTICAL DIVIDER ===== -->
        <Separator orientation="VERTICAL" styleClass="vertical-divider" />

        <!-- ===== RIGHT PANEL: MAP ===== -->
        <VBox spacing="0" styleClass="map-panel" HBox.hgrow="ALWAYS">

            <!-- Map toolbar -->
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="map-toolbar">
                <padding>
                    <Insets bottom="10" left="14" right="14" top="10" />
                </padding>

                <!-- Zoom controls -->
                <HBox spacing="0" styleClass="zoom-group">
                    <Button fx:id="zoomInBtn" styleClass="zoom-btn">
                        <graphic>
                            <FontAwesomeIconView glyphName="PLUS" size="12" styleClass="zoom-icon" />
                        </graphic>
                    </Button>
                    <Button fx:id="zoomOutBtn" styleClass="zoom-btn">
                        <graphic>
                            <FontAwesomeIconView glyphName="MINUS" size="12" styleClass="zoom-icon" />
                        </graphic>
                    </Button>
                </HBox>

                <Button fx:id="centerMapBtn" styleClass="toolbar-btn">
                    <graphic>
                        <HBox alignment="CENTER" spacing="6">
                            <FontAwesomeIconView glyphName="CROSSHAIRS" size="12" styleClass="toolbar-icon" />
                            <Label styleClass="toolbar-btn-text" text="Re-center" />
                        </HBox>
                    </graphic>
                </Button>

                <Button fx:id="undoLastBtn" styleClass="toolbar-btn">
                    <graphic>
                        <HBox alignment="CENTER" spacing="6">
                            <FontAwesomeIconView glyphName="UNDO" size="12" styleClass="toolbar-icon" />
                            <Label styleClass="toolbar-btn-text" text="Undo Last" />
                        </HBox>
                    </graphic>
                </Button>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Click mode indicator -->
                <HBox alignment="CENTER" spacing="6" styleClass="mode-indicator">
                    <FontAwesomeIconView fx:id="modeIcon" glyphName="MOUSE_POINTER" size="11" styleClass="mode-icon" />
                    <Label styleClass="mode-label" text="Click map to place point" />
                </HBox>
            </HBox>

            <!-- Map canvas container -->
            <Pane fx:id="mapContainer" styleClass="map-container" VBox.vgrow="ALWAYS" />

        </VBox>
    </HBox>

    <!-- ==================== FOOTER ==================== -->
    <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="dialog-footer">
        <padding>
            <Insets bottom="16" left="22" right="22" top="16" />
        </padding>

        <!-- Validation hint -->
        <HBox fx:id="validationHint" alignment="CENTER_LEFT" managed="false" spacing="6" styleClass="validation-hint" visible="false">
            <FontAwesomeIconView glyphName="EXCLAMATION_TRIANGLE" size="12" styleClass="hint-warn-icon" />
            <Label fx:id="validationHintLabel" styleClass="hint-warn-text" text="At least 3 points required." />
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <Button fx:id="cancelBtn" styleClass="btn-secondary">
            <graphic>
                <HBox alignment="CENTER" spacing="8">
                    <FontAwesomeIconView glyphName="TIMES" size="13" styleClass="btn-sec-icon" />
                    <Label styleClass="btn-sec-text" text="Cancel" />
                </HBox>
            </graphic>
        </Button>

        <Button fx:id="confirmBtn" prefHeight="40" prefWidth="160" styleClass="btn-primary">
            <graphic>
                <HBox alignment="CENTER" spacing="8">
                    <FontAwesomeIconView glyphName="CHECK" size="13" styleClass="btn-icon" />
                    <Label styleClass="btn-text" text="Confirm Points" />
                </HBox>
            </graphic>
        </Button>
    </HBox>

</VBox>
