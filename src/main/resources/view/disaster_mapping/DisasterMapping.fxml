<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="rootPane"
            styleClass="root-pane"
            stylesheets="@/styles/disaster_mapping/disaster_mapping.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ionres.respondph.disaster_mapping.DisasterMappingController">

    <VBox AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0">

        <!-- HEADER -->
        <VBox styleClass="header-section" VBox.vgrow="NEVER">

            <HBox alignment="CENTER_LEFT" spacing="16">
                <FontAwesomeIconView glyphName="MAP" size="24" styleClass="page-icon" />
                <VBox spacing="2">
                    <Label styleClass="page-title" text="Disaster Mapping" />
                    <Label styleClass="page-hint"
                           text="Select a disaster type first, then choose a disaster name — or select All Types to show all disasters." />
                </VBox>
            </HBox>

            <!-- TOOLBAR -->
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="toolbar">

                <!-- Disaster Type -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="search-box">
                    <FontAwesomeIconView glyphName="FILTER" size="14" styleClass="search-icon" />
                    <ComboBox fx:id="disasterTypeComboBox"
                              prefWidth="220"
                              promptText="Filter by type..."
                              styleClass="search-field" />
                </HBox>

                <!-- Disaster Name -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="search-box">
                    <FontAwesomeIconView glyphName="MAP_MARKER" size="14" styleClass="search-icon" />
                    <ComboBox fx:id="disasterComboBox"
                              prefWidth="320"
                              promptText="Choose a disaster..."
                              styleClass="search-field" />
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

            </HBox>

        </VBox>

        <!-- MAP AREA -->
        <VBox styleClass="table-container" VBox.vgrow="ALWAYS">
            <StackPane VBox.vgrow="ALWAYS">
                <Pane fx:id="mapContainer" styleClass="map-container" />
            </StackPane>
        </VBox>

    </VBox>
</AnchorPane>