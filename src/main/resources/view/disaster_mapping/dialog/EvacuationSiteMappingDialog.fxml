<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="evacMappingRoot" prefHeight="900.0" prefWidth="1200.0" styleClass="dialog-root" stylesheets="@/styles/disaster_mapping/dialog/evacuation_site_mapping.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ionres.respondph.disaster_mapping.dialogs_controller.EvacuationSiteMappingController">

    <!-- ==================== HEADER ==================== -->
    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="dialog-header">
        <padding>
            <Insets bottom="18" left="24" right="24" top="18" />
        </padding>

        <FontAwesomeIconView glyphName="HOME" size="22" styleClass="header-icon" />

        <VBox spacing="2">
            <Label styleClass="dialog-title" text="Evacuation Site Mapping" />
            <Label styleClass="dialog-subtitle" text="Review disaster area and nearby evacuation sites on the map." />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <Button fx:id="closeButton" styleClass="dialog-close">
            <graphic>
                <FontAwesomeIconView glyphName="TIMES" size="14" styleClass="close-icon" />
            </graphic>
        </Button>
    </HBox>

    <!-- ==================== INFO CARD ==================== -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="info-card">
        <padding>
            <Insets bottom="12" left="24" right="24" top="12" />
        </padding>
        <FontAwesomeIconView glyphName="EXCLAMATION_TRIANGLE" size="18" styleClass="info-card-icon" />
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label styleClass="info-card-title" text="Selected Disaster" />
            <Label fx:id="disasterInfoLabel" styleClass="info-card-text" text="No disaster selected" wrapText="true" />
        </VBox>
        <Label styleClass="pill" text="Mapping Mode" />
    </HBox>

    <!-- ==================== ERROR (optional) ==================== -->
    <HBox fx:id="errorBox" alignment="CENTER_LEFT" managed="false" spacing="10" styleClass="error-box" visible="false">
        <padding>
            <Insets bottom="10" left="24" right="24" top="10" />
        </padding>
        <FontAwesomeIconView glyphName="EXCLAMATION_CIRCLE" size="16" styleClass="error-icon" />
        <Label fx:id="errorLabel" styleClass="error-text" text="Error" wrapText="true" />
    </HBox>

    <!-- ==================== MAP (small left/right padding, no wrapper card) ==================== -->
    <VBox VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="12" left="12" right="12" top="12" />
        </padding>
        <Pane fx:id="mappingContainer" styleClass="map-surface" VBox.vgrow="ALWAYS" />
    </VBox>

</VBox>
