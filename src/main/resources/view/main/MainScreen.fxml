<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="824.0" prefWidth="321.0" styleClass="dashboard-root"
            stylesheets="@/styles/main/mainframe.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ionres.respondph.main.MainFrameController">

    <left>
        <VBox styleClass="sidebar">

            <VBox alignment="CENTER" styleClass="logo-section">
                <StackPane prefHeight="110.0" prefWidth="240.0" styleClass="logo-container">
                    <padding>
                        <Insets bottom="14.0" left="18.0" right="18.0" top="18.0" />
                    </padding>
                </StackPane>
                <Label styleClass="brand-subtitle" text="Disaster Response System" />
            </VBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="nav-scroll-pane"
                        vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
                <VBox styleClass="nav-menu">

                    <Button fx:id="dashboardBtn" maxWidth="1.7976931348623157E308" styleClass="nav-button">
                        <graphic>
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="nav-row">
                                <FontAwesomeIconView glyphName="HOME" styleClass="nav-icon" />
                                <Label styleClass="nav-text" text="Dashboard" />
                            </HBox>
                        </graphic>
                    </Button>

                    <!-- Management -->
                    <VBox styleClass="tree-section">
                        <Button fx:id="managementSectionBtn" maxWidth="1.7976931348623157E308" styleClass="tree-section-header">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="nav-row">
                                    <FontAwesomeIconView fx:id="managementSectionIcon" glyphName="CHEVRON_RIGHT" styleClass="tree-chevron" />
                                    <Label styleClass="tree-section-title" text="Management" />
                                </HBox>
                            </graphic>
                        </Button>
                        <VBox fx:id="managementSectionContent" managed="false" styleClass="tree-section-content" visible="false">
                            <Button fx:id="manageAdminBtn" maxWidth="1.7976931348623157E308" styleClass="nav-button-child">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="nav-row">
                                        <FontAwesomeIconView glyphName="USER" styleClass="nav-icon-sm" />
                                        <Label styleClass="nav-text" text="Manage Admins" />
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button fx:id="manageBeneficiariesBtn" maxWidth="1.7976931348623157E308" styleClass="nav-button-child">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="nav-row">
                                        <FontAwesomeIconView glyphName="USERS" styleClass="nav-icon-sm" />
                                        <Label styleClass="nav-text" text="Manage Beneficiaries" />
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button fx:id="familyMembersBtn" maxWidth="1.7976931348623157E308" styleClass="nav-button-child">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="nav-row">
                                        <FontAwesomeIconView glyphName="USER_PLUS" styleClass="nav-icon-sm" />
                                        <Label styleClass="nav-text" text="Family Members" />
                                    </HBox>
                                </graphic>
                            </Button>
                        </VBox>
                    </VBox>

                    <!-- Disaster -->
                    <VBox styleClass="tree-section">
                        <Button fx:id="disasterSectionBtn" maxWidth="1.7976931348623157E308" styleClass="tree-section-header">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="nav-row">
                                    <FontAwesomeIconView fx:id="disasterSectionIcon" glyphName="CHEVRON_RIGHT" styleClass="tree-chevron" />
                                    <Label styleClass="tree-section-title" text="Disaster Management" />
                                </HBox>
                            </graphic>
                        </Button>
                        <VBox fx:id="disasterSectionContent" managed="false" styleClass="tree-section-content" visible="false">
                            <Button fx:id="disasterBtn" maxWidth="1.7976931348623157E308" styleClass="nav-button-child">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="nav-row">
                                        <FontAwesomeIconView glyphName="EXCLAMATION_TRIANGLE" styleClass="nav-icon-sm" />
                                        <Label styleClass="nav-text" text="Disaster" />
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button fx:id="disasterMappingBtn" maxWidth="1.7976931348623157E308" styleClass="nav-button-child">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="nav-row">
                                        <FontAwesomeIconView glyphName="MAP_MARKER" styleClass="nav-icon-sm" />
                                        <Label styleClass="nav-text" text="Disaster Mapping" />
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button fx:id="disasterDamageBtn" maxWidth="1.7976931348623157E308" styleClass="nav-button-child">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="nav-row">
                                        <FontAwesomeIconView glyphName="FIRE" styleClass="nav-icon-sm" />
                                        <Label styleClass="nav-text" text="Disaster Damage" />
                                    </HBox>
                                </graphic>
                            </Button>
                        </VBox>
                    </VBox>

                    <!-- Aids Management -->
                    <VBox styleClass="tree-section">
                        <Button fx:id="aidsSectionBtn" maxWidth="1.7976931348623157E308" styleClass="tree-section-header">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="nav-row">
                                    <FontAwesomeIconView fx:id="aidsSectionIcon" glyphName="CHEVRON_RIGHT" styleClass="tree-chevron" />
                                    <Label styleClass="tree-section-title" text="Aids Management" />
                                </HBox>
                            </graphic>
                        </Button>
                        <VBox fx:id="aidsSectionContent" managed="false" styleClass="tree-section-content" visible="false">
                            <Button fx:id="aidBtn" maxWidth="1.7976931348623157E308" styleClass="nav-button-child">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="nav-row">
                                        <FontAwesomeIconView glyphName="MEDKIT" styleClass="nav-icon-sm" />
                                        <Label styleClass="nav-text" text="Aid" />
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button fx:id="aidTypeBtn" maxWidth="1.7976931348623157E308" styleClass="nav-button-child">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="nav-row">
                                        <FontAwesomeIconView glyphName="CUTLERY" styleClass="nav-icon-sm" />
                                        <Label styleClass="nav-text" text="Aid Type" />
                                    </HBox>
                                </graphic>
                            </Button>
                        </VBox>
                    </VBox>

                    <!-- Evacuation Site Management -->
                    <VBox styleClass="tree-section">
                        <Button fx:id="evacSectionBtn" maxWidth="1.7976931348623157E308" styleClass="tree-section-header">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="nav-row">
                                    <FontAwesomeIconView fx:id="evacSectionIcon" glyphName="CHEVRON_RIGHT" styleClass="tree-chevron" />
                                    <Label styleClass="tree-section-title" text="Evacuation Site Management" />
                                </HBox>
                            </graphic>
                        </Button>
                        <VBox fx:id="evacSectionContent" managed="false" styleClass="tree-section-content" visible="false">
                            <Button fx:id="evacBtn" maxWidth="1.7976931348623157E308" styleClass="nav-button-child">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="nav-row">
                                        <FontAwesomeIconView glyphName="BUILDING" styleClass="nav-icon-sm" />
                                        <Label styleClass="nav-text" text="Evacuation Site" />
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button fx:id="evacPlanBtn" maxWidth="1.7976931348623157E308" styleClass="nav-button-child">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="nav-row">
                                        <FontAwesomeIconView glyphName="MAP" styleClass="nav-icon-sm" />
                                        <Label styleClass="nav-text" text="Evacuation Plan" />
                                    </HBox>
                                </graphic>
                            </Button>
                        </VBox>
                    </VBox>

                    <!-- Quick links -->
                    <Button fx:id="vulnerabilityBtn" maxWidth="1.7976931348623157E308" styleClass="nav-button">
                        <graphic>
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="nav-row">
                                <FontAwesomeIconView glyphName="SHIELD" styleClass="nav-icon" />
                                <Label styleClass="nav-text" text="Vulnerability Indicator" />
                            </HBox>
                        </graphic>
                    </Button>

                    <Button fx:id="sendSmsBtn" maxWidth="1.7976931348623157E308" styleClass="nav-button">
                        <graphic>
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="nav-row">
                                <FontAwesomeIconView glyphName="PAPER_PLANE" styleClass="nav-icon" />
                                <Label styleClass="nav-text" text="Send SMS" />
                            </HBox>
                        </graphic>
                    </Button>

                </VBox>
            </ScrollPane>

            <!-- Logout -->
            <VBox styleClass="logout-section">
                <Button fx:id="logoutBtn" maxWidth="1.7976931348623157E308" styleClass="logout-button">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="nav-row">
                            <FontAwesomeIconView glyphName="SIGN_OUT" styleClass="logout-icon" />
                            <Label styleClass="logout-text" text="Logout" />
                        </HBox>
                    </graphic>
                </Button>
            </VBox>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentShell" styleClass="content-shell">
            <VBox fx:id="contentArea" styleClass="content-area" />

            <VBox spacing="8"
                  fillWidth="false"
                  alignment="BOTTOM_RIGHT"
                  pickOnBounds="false"
                  mouseTransparent="false"
                  StackPane.alignment="BOTTOM_RIGHT">

                <!-- SMS PROGRESS TOAST -->
                <VBox fx:id="smsProgressToast"
                      fillWidth="true" managed="false" visible="false"
                      pickOnBounds="false"
                      maxHeight="-1" maxWidth="-1"
                      spacing="0" styleClass="sms-toast">

                    <HBox alignment="CENTER_LEFT" maxWidth="-1" spacing="8" styleClass="sms-toast-header">
                        <Label fx:id="smsProgressTitle" maxWidth="1.7976931348623157E308"
                               styleClass="sms-toast-title" text="Sending SMS"
                               HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_RIGHT" spacing="6">
                            <Button fx:id="smsMinimizeBtn" styleClass="sms-icon-btn" text="–" />
                            <Button fx:id="smsCloseBtn"    styleClass="sms-icon-btn" text="✕" />
                        </HBox>
                    </HBox>

                    <VBox fx:id="smsToastBody" fillWidth="true" maxHeight="-1" maxWidth="-1"
                          spacing="6" styleClass="sms-toast-body">
                        <Label fx:id="smsProgressMessage" maxWidth="1.7976931348623157E308"
                               styleClass="sms-toast-subtitle" text="Sending 0 of 0" wrapText="true" />
                        <ProgressBar fx:id="smsProgressBar" maxWidth="1.7976931348623157E308"
                                     styleClass="sms-toast-progress" />
                    </VBox>

                </VBox>

                <VBox fx:id="newsProgressToast"
                      fillWidth="true" managed="false" visible="false"
                      pickOnBounds="false"
                      maxHeight="-1" maxWidth="-1"
                      spacing="0" styleClass="sms-toast">

                    <HBox alignment="CENTER_LEFT" maxWidth="-1" spacing="8" styleClass="sms-toast-header">
                        <Label fx:id="newsProgressTitle" maxWidth="1.7976931348623157E308"
                               styleClass="sms-toast-title" text="AI News Generator"
                               HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_RIGHT" spacing="6">
                            <Button fx:id="newsMinimizeBtn" styleClass="sms-icon-btn" text="–" />
                            <Button fx:id="newsCloseBtn"    styleClass="sms-icon-btn" text="✕" />
                        </HBox>
                    </HBox>

                    <VBox fx:id="newsToastBody" fillWidth="true" maxHeight="-1" maxWidth="-1"
                          spacing="6" styleClass="sms-toast-body">
                        <ProgressBar fx:id="newsProgressBar" maxWidth="1.7976931348623157E308"
                                     styleClass="sms-toast-progress" />
                    </VBox>

                </VBox>

            </VBox>
        </StackPane>
    </center>

    <bottom>
        <HBox fx:id="footerBar" alignment="CENTER_RIGHT" managed="false"
              styleClass="main-footer" visible="false">

            <Region HBox.hgrow="ALWAYS" />

            <HBox fx:id="smsFooterPill" alignment="CENTER_LEFT" managed="false"
                  spacing="8" styleClass="footer-pill" visible="false">
                <Label fx:id="footerSmsLabel" styleClass="footer-text" text="📨 Sending…" />
                <Button fx:id="btnShowSmsProgress" styleClass="footer-link-button" text="Show" />
            </HBox>

            <Label fx:id="footerDivider" managed="false" styleClass="footer-divider"
                   text=" · " visible="false" />

            <HBox fx:id="newsFooterPill" alignment="CENTER_LEFT" managed="false"
                  spacing="8" styleClass="footer-pill" visible="false">
                <Label fx:id="footerNewsLabel" styleClass="footer-text" text="🤖 AI generating…" />
                <Button fx:id="btnShowNewsProgress" styleClass="footer-link-button" text="Show" />
            </HBox>

        </HBox>
    </bottom>

</BorderPane>