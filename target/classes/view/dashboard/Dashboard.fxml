<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane styleClass="dashboard-root" stylesheets="@/styles/dashboard/dashboard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ionres.respondph.dashboard.DashboardController">

    <VBox spacing="15.0" styleClass="dashboard-wrapper" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <HBox alignment="CENTER_LEFT" styleClass="dashboard-topbar">
            <Label styleClass="dashboard-topbar-title" text="Dashboard Mapping" />

            <Region HBox.hgrow="ALWAYS" />

            <VBox alignment="CENTER" spacing="4" styleClass="clock-container">
                <Label fx:id="currentTimeLabel" styleClass="clock-time" />
                <Label fx:id="currentDateLabel" styleClass="clock-date" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER_RIGHT" spacing="8" styleClass="admin-name-label">
                <FontAwesomeIconView glyphName="USER_CIRCLE" styleClass="admin-icon-inside" />
                <Label fx:id="adminNameLabel" text="Admin Name" />
            </HBox>
        </HBox>

        <GridPane hgap="16" styleClass="cards-grid" vgap="16">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <StackPane fx:id="cardBeneficiary" styleClass="flat-card-blue" GridPane.columnIndex="0">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="flat-card-content">
                    <StackPane styleClass="flat-icon">
                        <FontAwesomeIconView glyphName="USERS" styleClass="flat-icon-symbol" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="totalBeneficiaryLabel" styleClass="flat-value" text="0" />
                        <Label styleClass="flat-label" text="Beneficiaries" />
                    </VBox>
                </HBox>
            </StackPane>

            <StackPane fx:id="cardDisasters" styleClass="flat-card-red" GridPane.columnIndex="1">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="flat-card-content">
                    <StackPane styleClass="flat-icon">
                        <FontAwesomeIconView glyphName="EXCLAMATION_TRIANGLE" styleClass="flat-icon-symbol" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="totalDisastersLabel" styleClass="flat-value" text="0" />
                        <Label styleClass="flat-label" text="Disasters" />
                    </VBox>
                </HBox>
            </StackPane>

            <StackPane fx:id="cardAids" styleClass="flat-card-green" GridPane.columnIndex="2">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="flat-card-content">
                    <StackPane styleClass="flat-icon">
                        <FontAwesomeIconView glyphName="MEDKIT" styleClass="flat-icon-symbol" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="totalAidsLabel" styleClass="flat-value" text="0" />
                        <Label styleClass="flat-label" text="Aids" />
                    </VBox>
                </HBox>
            </StackPane>

            <StackPane fx:id="cardEvacuationSite" styleClass="flat-card-yellow" GridPane.columnIndex="3">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="flat-card-content">
                    <StackPane styleClass="flat-icon">
                        <FontAwesomeIconView glyphName="HOME" styleClass="flat-icon-symbol" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="totalEvacutaionSiteLabel" styleClass="flat-value" text="0" />
                        <Label styleClass="flat-label" text="Evacuation Site" />
                    </VBox>
                </HBox>
            </StackPane>

            <rowConstraints>
                <RowConstraints />
            </rowConstraints>
        </GridPane>

        <StackPane VBox.vgrow="ALWAYS" styleClass="map-wrapper">
            <Pane fx:id="mapContainer" styleClass="map-container"
                  StackPane.alignment="CENTER" />

            <HBox fx:id="searchOverlay"
                  alignment="TOP_RIGHT"
                  spacing="8"
                  styleClass="map-search-overlay"
                  StackPane.alignment="TOP_RIGHT"
                  pickOnBounds="false">

                <!--
                    FIX #11: Added VBox.vgrow="NEVER" so the wrapper does not
                    stretch inside the HBox and push layout unpredictably.
                    FIX #13: Added prefWidth="280" on the ListView so it exactly
                    matches the TextField width (280px set in CSS), preventing the
                    list from collapsing to 0 width before the controller sets it
                    programmatically.
                -->
                <VBox fx:id="searchBoxWrap"
                      spacing="0"
                      alignment="TOP_RIGHT"
                      pickOnBounds="false"
                      managed="false"
                      visible="false"
                      VBox.vgrow="NEVER">

                    <TextField fx:id="beneficiarySearchBox"
                               promptText="Find beneficiary."
                               styleClass="map-search-combobox"
                               visible="true"
                               managed="true" />

                    <!-- FIX #13: prefWidth matches TextField's CSS pref-width (280px) -->
                    <ListView fx:id="beneficiarySearchList"
                              prefWidth="280"
                              styleClass="search-popup-list"
                              managed="false"
                              visible="false"
                              VBox.vgrow="NEVER" />
                </VBox>

                <!--
                    FIX: Wrap the button in a VBox with alignment=TOP so it stays
                    pinned to the top edge regardless of how tall the ListView grows.
                    A bare Button inside an HBox will vertically center when the HBox
                    stretches to fit the ListView height.
                -->
                <VBox alignment="TOP_CENTER" HBox.hgrow="NEVER">
                    <Button fx:id="searchToggleBtn"
                            styleClass="map-search-btn">
                        <graphic>
                            <FontAwesomeIconView glyphName="SEARCH" styleClass="map-search-icon" />
                        </graphic>
                    </Button>
                </VBox>
            </HBox>
        </StackPane>
    </VBox>
</AnchorPane>
