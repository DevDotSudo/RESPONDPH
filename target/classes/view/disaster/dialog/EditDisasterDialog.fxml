<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.*?>
<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="root" prefHeight="750.0" spacing="0" styleClass="dialog-root" stylesheets="@/styles/disaster/dialog/editdisasterdialog.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ionres.respondph.disaster.dialogs_controller.EditDisasterDialogController">

    <!-- ==================== HEADER SECTION ==================== -->
    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="dialog-header">
        <padding>
            <Insets bottom="18" left="24" right="24" top="18" />
        </padding>

        <FontAwesomeIconView glyphName="EDIT" size="22" styleClass="header-icon" />
        <VBox spacing="2">
            <Label styleClass="dialog-title" text="Edit Disaster Event" />
            <Label styleClass="dialog-subtitle" text="Update disaster event information. Fields marked with * are required." />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <Button fx:id="exitBtn" styleClass="dialog-close">
            <graphic>
                <HBox alignment="CENTER" spacing="8">
                    <FontAwesomeIconView glyphName="TIMES" size="14" styleClass="close-icon" />
                </HBox>
            </graphic>
        </Button>
    </HBox>

    <!-- ==================== ERROR CONTAINER ==================== -->
    <VBox alignment="CENTER" managed="false" styleClass="error-box" visible="false">
        <padding>
            <Insets bottom="12" left="24" right="24" top="10" />
        </padding>
        <Label fx:id="errorLabel" styleClass="error-text" />
    </VBox>

    <!-- ==================== MAIN FORM CONTAINER ==================== -->
    <ScrollPane fitToWidth="true" styleClass="dialog-scroll" VBox.vgrow="ALWAYS">
        <VBox spacing="24" styleClass="dialog-body">
            <padding>
                <Insets bottom="24" left="24" right="24" top="20" />
            </padding>

            <!-- ==================== SECTION 1: DISASTER INFORMATION ==================== -->
            <VBox spacing="18" styleClass="form-section">
                <!-- Section Header -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="INFO_CIRCLE" size="18" styleClass="section-icon" />
                    <Label styleClass="section-title" text="Disaster Information" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="section-subtitle" text="Step 1 of 3" />
                </HBox>

                <!-- Disaster Fields -->
                <GridPane hgap="16" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                    </columnConstraints>

                    <!-- Disaster Type -->
                    <VBox spacing="8" GridPane.columnIndex="0">
                        <Label styleClass="field-label" text="Disaster Type *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="FIRE" size="14" styleClass="field-icon" />
                            <ComboBox fx:id="disasterType" maxWidth="1.7976931348623157E308" promptText="Select disaster type" styleClass="field-combo" HBox.hgrow="ALWAYS">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Bioterrorism" />
                                        <String fx:value="Civil Unrest" />
                                        <String fx:value="Cold Wave" />
                                        <String fx:value="Drought" />
                                        <String fx:value="Earthquake" />
                                        <String fx:value="Epidemic" />
                                        <String fx:value="Famine" />
                                        <String fx:value="Fire (Urban)" />
                                        <String fx:value="Fire (Wild)" />
                                        <String fx:value="Flash Flood" />
                                        <String fx:value="Flood" />
                                        <String fx:value="Hazardous Material Spills" />
                                        <String fx:value="Heat Wave" />
                                        <String fx:value="Insect Infestation" />
                                        <String fx:value="Land Slide" />
                                        <String fx:value="Massacre" />
                                        <String fx:value="Mud Slide" />
                                        <String fx:value="Nuclear Radiation Accidents" />
                                        <String fx:value="Power Failure" />
                                        <String fx:value="Riot" />
                                        <String fx:value="Storm Surge" />
                                        <String fx:value="Structural Failures and Collapses" />
                                        <String fx:value="Technological Disaster" />
                                        <String fx:value="Tsunami" />
                                        <String fx:value="Typhoon" />
                                        <String fx:value="Volcano" />
                                        <String fx:value="War" />
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </HBox>
                    </VBox>

                    <!-- Disaster Name -->
                    <VBox spacing="8" GridPane.columnIndex="1">
                        <Label styleClass="field-label" text="Disaster Name *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="FIRE" size="14" styleClass="field-icon" />
                            <TextField fx:id="disasterNameFld" maxWidth="1.7976931348623157E308" promptText="Enter disaster name" styleClass="field-input" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>

                    <!-- Disaster Date -->
                    <VBox spacing="8" GridPane.columnIndex="2">
                        <Label styleClass="field-label" text="Disaster Date *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="CALENDAR" size="14" styleClass="field-icon" />
                            <DatePicker fx:id="datePicker" maxWidth="1.7976931348623157E308" promptText="Select date" styleClass="field-date" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                    <rowConstraints>
                        <RowConstraints />
                    </rowConstraints>
                </GridPane>
            </VBox>

            <Separator />

            <!-- ==================== SECTION 2: LOCATION INFORMATION ==================== -->
            <VBox spacing="18" styleClass="form-section" VBox.vgrow="NEVER">
                <!-- Section Header -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="MAP_MARKER" size="18" styleClass="section-icon" />
                    <Label styleClass="section-title" text="Location Information" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="section-subtitle" text="Step 2 of 3" />
                </HBox>

                <!-- Banate Area Checkbox -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="banate-area-box">
                    <CheckBox fx:id="banateAreaCheckBox" styleClass="banate-checkbox" />
                    <VBox spacing="2">
                        <Label styleClass="banate-label" text="Banate Area" />
                        <Label styleClass="banate-description" text="Covers the entire Banate municipal boundary — disables location fields" />
                    </VBox>
                </HBox>

                <!-- ==================== LOCATION TYPE TABPANE ==================== -->
                <TabPane fx:id="locationTabPane" maxHeight="-1" minHeight="-1" prefHeight="-1" styleClass="location-tab-pane" tabClosingPolicy="UNAVAILABLE">

                    <!-- ===== TAB 1: CIRCLE ===== -->
                    <Tab fx:id="circleTab" styleClass="location-tab">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8">
                                <Label styleClass="tab-label" text="Circle" />
                            </HBox>
                        </graphic>
                        <content>
                            <VBox spacing="16" styleClass="tab-content-pane">
                                <padding>
                                    <Insets bottom="18" left="16" right="16" top="18" />
                                </padding>

                                <!-- Get Location Button -->
                                <HBox alignment="CENTER_LEFT">
                                    <Button fx:id="getLocationBtn" styleClass="action-button">
                                        <graphic>
                                            <HBox alignment="CENTER" spacing="10">
                                                <FontAwesomeIconView glyphName="LOCATION_ARROW" size="14" styleClass="action-icon" />
                                                <Label styleClass="action-text" text="Get Location" />
                                            </HBox>
                                        </graphic>
                                    </Button>
                                </HBox>

                                <!-- Location Fields -->
                                <GridPane hgap="16" vgap="14">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                                    </columnConstraints>

                                    <!-- Latitude -->
                                    <VBox spacing="8" GridPane.columnIndex="0">
                                        <Label styleClass="field-label" text="Latitude *" />
                                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                                            <FontAwesomeIconView glyphName="GLOBE" size="14" styleClass="field-icon" />
                                            <TextField fx:id="latitudeFld" promptText="Enter latitude" styleClass="field-input" HBox.hgrow="ALWAYS" />
                                        </HBox>
                                    </VBox>

                                    <!-- Longitude -->
                                    <VBox spacing="8" GridPane.columnIndex="1">
                                        <Label styleClass="field-label" text="Longitude *" />
                                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                                            <FontAwesomeIconView glyphName="GLOBE" size="14" styleClass="field-icon" />
                                            <TextField fx:id="longitudeFld" promptText="Enter longitude" styleClass="field-input" HBox.hgrow="ALWAYS" />
                                        </HBox>
                                    </VBox>

                                    <!-- Radius -->
                                    <VBox spacing="8" GridPane.columnIndex="2">
                                        <Label styleClass="field-label" text="Radius (meters) *" />
                                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                                            <FontAwesomeIconView glyphName="COMPASS" size="14" styleClass="field-icon" />
                                            <TextField fx:id="radiusFld" promptText="Enter radius" styleClass="field-input" HBox.hgrow="ALWAYS" />
                                        </HBox>
                                    </VBox>
                                    <rowConstraints>
                                        <RowConstraints />
                                    </rowConstraints>
                                </GridPane>
                            </VBox>
                        </content>
                    </Tab>

                    <!-- ===== TAB 2: POLYGON ===== -->
                    <Tab fx:id="polygonTab" styleClass="location-tab">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8">
                                <Label styleClass="tab-label" text="Polygon" />
                            </HBox>
                        </graphic>
                        <content>
                            <VBox spacing="16" styleClass="tab-content-pane">
                                <padding>
                                    <Insets bottom="18" left="16" right="16" top="18" />
                                </padding>

                                <!-- Select on Map Button -->
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <Button fx:id="selectOnMapBtn" styleClass="action-button">
                                        <graphic>
                                            <HBox alignment="CENTER" spacing="10">
                                                <FontAwesomeIconView glyphName="MAP_MARKER" size="14" styleClass="action-icon" />
                                                <Label styleClass="action-text" text="Select on Map" />
                                            </HBox>
                                        </graphic>
                                    </Button>
                                    <Label styleClass="polygon-hint-label" text="Click points on the map to define the polygon boundary." />
                                </HBox>

                                <!-- Polygon Points List Header -->
                                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="polygon-list-header">
                                    <FontAwesomeIconView glyphName="LIST" size="12" styleClass="polygon-header-icon" />
                                    <Label styleClass="polygon-header-label" text="Selected Points" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="polygonPointCountLabel" styleClass="polygon-count-badge" text="0 points" />
                                </HBox>

                                <!-- Polygon Points Empty State -->
                                <VBox fx:id="polygonEmptyState" alignment="CENTER" spacing="10" styleClass="polygon-empty-state">
                                    <padding>
                                        <Insets bottom="24" left="16" right="16" top="24" />
                                    </padding>
                                    <FontAwesomeIconView glyphName="MAP_O" size="28" styleClass="polygon-empty-icon" />
                                    <Label styleClass="polygon-empty-title" text="No Points Selected" />
                                    <Label styleClass="polygon-empty-desc" text="Use &quot;Select on Map&quot; to add polygon boundary points." />
                                </VBox>

                                <!-- Polygon Points List Container -->
                                <ScrollPane fx:id="polygonScrollPane" fitToWidth="true" managed="false" maxHeight="200" minHeight="0" styleClass="polygon-scroll" visible="false">
                                    <VBox fx:id="polygonPointsContainer" spacing="6" styleClass="polygon-points-list">
                                        <padding>
                                            <Insets bottom="6" left="4" right="4" top="6" />
                                        </padding>
                                    </VBox>
                                </ScrollPane>

                            </VBox>
                        </content>
                    </Tab>

                </TabPane>
            </VBox>

            <Separator />

            <!-- ==================== SECTION 3: ADDITIONAL INFORMATION ==================== -->
            <VBox spacing="18" styleClass="form-section">
                <!-- Section Header -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="STICKY_NOTE" size="18" styleClass="section-icon" />
                    <Label styleClass="section-title" text="Additional Information" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="section-subtitle" text="Step 3 of 3" />
                </HBox>

                <!-- Notes Field -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Notes" />
                    <VBox styleClass="flat-input-textarea">
                        <TextArea fx:id="notesFld" prefRowCount="4" promptText="Enter any additional notes about this disaster (optional)" styleClass="field-textarea" wrapText="true" />
                    </VBox>
                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- ==================== FOOTER SECTION ==================== -->
    <HBox alignment="CENTER_RIGHT" spacing="14" styleClass="dialog-footer">
        <padding>
            <Insets bottom="20" left="24" right="24" top="20" />
        </padding>

        <Button fx:id="updateBtn" prefHeight="42.0" prefWidth="200.0" styleClass="btn-primary">
            <graphic>
                <HBox alignment="CENTER" spacing="10">
                    <FontAwesomeIconView glyphName="SAVE" size="16" styleClass="btn-icon" />
                    <Label styleClass="btn-text" text="Update Disaster" />
                </HBox>
            </graphic>
        </Button>
    </HBox>

</VBox>
