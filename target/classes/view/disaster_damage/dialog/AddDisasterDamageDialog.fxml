<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.*?>
<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="root" prefHeight="900.0" prefWidth="1200.0" spacing="0"
      styleClass="dialog-root"
      stylesheets="@/styles/disaster_damage/dialog/adddisasterdamagedialog.css"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ionres.respondph.disaster_damage.dialogs_controller.AddDisasterDamageDialogController">

    <!-- ==================== HEADER ==================== -->
    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="dialog-header">
        <padding><Insets bottom="18" left="24" right="24" top="18" /></padding>
        <FontAwesomeIconView glyphName="FIRE" size="22" styleClass="header-icon" />
        <VBox spacing="2">
            <Label styleClass="dialog-title" text="Add Disaster Damage" />
            <Label styleClass="dialog-subtitle" text="Fields marked with * are required. Please fill out all sections completely." />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="exitBtn" styleClass="dialog-close">
            <graphic>
                <HBox alignment="CENTER" spacing="8">
                    <FontAwesomeIconView glyphName="TIMES" size="14" styleClass="close-icon" />
                </HBox>
            </graphic>
        </Button>
    </HBox>

    <!-- ==================== SCROLLABLE BODY ==================== -->
    <ScrollPane fitToWidth="true" styleClass="dialog-scroll" VBox.vgrow="ALWAYS">
        <VBox spacing="24" styleClass="dialog-body">
            <padding><Insets bottom="24" left="24" right="24" top="20" /></padding>

            <!-- ── SECTION 1: SEARCH ── -->
            <VBox spacing="18" styleClass="form-section" viewOrder="-1">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="SEARCH" size="18" styleClass="section-icon" />
                    <Label styleClass="section-title" text="Search" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="section-subtitle" text="Step 1 of 3" />
                </HBox>

                <VBox spacing="6" styleClass="info-box">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <FontAwesomeIconView glyphName="INFO_CIRCLE" size="14" styleClass="info-icon" />
                        <Label styleClass="info-title" text="Search Information" />
                    </HBox>
                    <Label styleClass="info-text" text="• Search and select a beneficiary affected by the disaster" />
                    <Label styleClass="info-text" text="• Search and select the specific disaster event" />
                    <Label styleClass="info-text" text="• You can search by typing names or IDs" />
                </VBox>

                <!-- Two search fields side by side -->
                <GridPane hgap="16" vgap="0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                    </columnConstraints>

                    <!-- LEFT: Beneficiary search -->
                    <VBox spacing="8" GridPane.columnIndex="0">
                        <Label styleClass="field-label" text="Search Beneficiary *" />
                        <StackPane fx:id="beneficiarySearchWrap"
                                   minHeight="44" prefHeight="44" maxHeight="44">
                            <HBox fx:id="beneficiaryInputRow"
                                  alignment="CENTER_LEFT" spacing="10"
                                  styleClass="flat-input,beneficiary-search-input"
                                  StackPane.alignment="TOP_CENTER">
                                <FontAwesomeIconView glyphName="USER" size="14" styleClass="field-icon" />
                                <TextField fx:id="beneficiarySearchFld"
                                           promptText="Type to search beneficiary name or ID"
                                           styleClass="field-input"
                                           HBox.hgrow="ALWAYS" />
                                <FontAwesomeIconView fx:id="beneficiaryCaretIcon"
                                                     glyphName="CHEVRON_DOWN" size="11"
                                                     styleClass="beneficiary-caret-icon" />
                            </HBox>
                            <ListView fx:id="beneficiarySearchList"
                                      styleClass="search-popup-list"
                                      translateY="44"
                                      viewOrder="-1"
                                      visible="false"
                                      StackPane.alignment="TOP_CENTER" />
                        </StackPane>
                    </VBox>

                    <!-- RIGHT: Disaster search -->
                    <VBox spacing="8" GridPane.columnIndex="1">
                        <Label styleClass="field-label" text="Search Disaster *" />
                        <StackPane fx:id="disasterSearchWrap"
                                   minHeight="44" prefHeight="44" maxHeight="44">
                            <HBox fx:id="disasterInputRow"
                                  alignment="CENTER_LEFT" spacing="10"
                                  styleClass="flat-input,beneficiary-search-input"
                                  StackPane.alignment="TOP_CENTER">
                                <FontAwesomeIconView glyphName="FIRE" size="14" styleClass="field-icon" />
                                <TextField fx:id="disasterSearchFld"
                                           promptText="Type to search disaster name or ID"
                                           styleClass="field-input"
                                           HBox.hgrow="ALWAYS" />
                                <FontAwesomeIconView fx:id="disasterCaretIcon"
                                                     glyphName="CHEVRON_DOWN" size="11"
                                                     styleClass="beneficiary-caret-icon" />
                            </HBox>
                            <ListView fx:id="disasterSearchList"
                                      styleClass="search-popup-list"
                                      translateY="44"
                                      viewOrder="-1"
                                      visible="false"
                                      StackPane.alignment="TOP_CENTER" />
                        </StackPane>
                    </VBox>

                    <rowConstraints><RowConstraints /></rowConstraints>
                </GridPane>
            </VBox>

            <Separator />

            <!-- ── SECTION 2: DAMAGE ASSESSMENT ── -->
            <VBox spacing="18" styleClass="form-section">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="CLIPBOARD" size="18" styleClass="section-icon" />
                    <Label styleClass="section-title" text="Damage Assessment" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="section-subtitle" text="Step 2 of 3" />
                </HBox>

                <GridPane hgap="16" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                    </columnConstraints>

                    <VBox spacing="8" GridPane.columnIndex="0">
                        <Label styleClass="field-label" text="House Damage Severity *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="FIRE" size="14" styleClass="field-icon" />
                            <ComboBox fx:id="damageSeverityFld" maxWidth="1.7976931348623157E308"
                                      promptText="Select damage severity"
                                      styleClass="field-combo" HBox.hgrow="ALWAYS">
                                <items><FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Affected" />
                                    <String fx:value="Partially Damaged" />
                                    <String fx:value="Totally Damaged" />
                                </FXCollections></items>
                            </ComboBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="1">
                        <Label styleClass="field-label" text="Assessment Date *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="CALENDAR" size="14" styleClass="field-icon" />
                            <DatePicker fx:id="assessmentDatePicker" maxWidth="1.7976931348623157E308"
                                        promptText="Select date"
                                        styleClass="field-date" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="2">
                        <Label styleClass="field-label" text="Verified By *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="CHECK" size="14" styleClass="field-icon" />
                            <TextField fx:id="verifiedByFld" promptText="Enter verifier name"
                                       styleClass="field-input" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>

                    <rowConstraints><RowConstraints /></rowConstraints>
                </GridPane>
            </VBox>

            <Separator />

            <!-- ── SECTION 3: DAMAGE PHOTO UPLOAD ── -->
            <VBox spacing="18" styleClass="form-section">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="CAMERA" size="18" styleClass="section-icon" />
                    <Label styleClass="section-title" text="Damage Photo" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="section-subtitle" text="Step 3 of 3" />
                </HBox>

                <VBox spacing="6" styleClass="info-box">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <FontAwesomeIconView glyphName="INFO_CIRCLE" size="14" styleClass="info-icon" />
                        <Label styleClass="info-title" text="Photo Upload (Optional)" />
                    </HBox>
                    <Label styleClass="info-text" text="• Upload a clear photo of the damaged area or structure" />
                    <Label styleClass="info-text" text="• Accepted formats: JPG, PNG, JPEG — Max size: 5MB" />
                    <Label styleClass="info-text" text="• Photos help verify and document damage severity accurately" />
                </VBox>

                <GridPane hgap="20" vgap="0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="45" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="55" />
                    </columnConstraints>
                    <rowConstraints><RowConstraints minHeight="200" /></rowConstraints>

                    <!-- LEFT: Upload instructions + button -->
                    <VBox alignment="CENTER" spacing="16" styleClass="upload-instruction-panel"
                          GridPane.columnIndex="0">
                        <padding><Insets bottom="24" left="20" right="20" top="24" /></padding>
                        <StackPane maxHeight="64" maxWidth="64" styleClass="upload-icon-badge">
                            <FontAwesomeIconView glyphName="CLOUD_UPLOAD" size="28" styleClass="upload-badge-icon" />
                        </StackPane>
                        <Label maxWidth="220" styleClass="upload-panel-title"
                               text="Upload Damage Photo" textAlignment="CENTER" wrapText="true" />
                        <Label maxWidth="220" styleClass="upload-panel-desc"
                               text="Take or select a clear photo showing the extent of damage to the structure."
                               textAlignment="CENTER" wrapText="true" />
                        <HBox alignment="CENTER" spacing="8">
                            <Label styleClass="upload-tag" text="JPG" />
                            <Label styleClass="upload-tag" text="PNG" />
                            <Label styleClass="upload-tag" text="Max 5MB" />
                        </HBox>
                        <Button fx:id="uploadPhotoBtn" styleClass="btn-upload">
                            <graphic>
                                <HBox alignment="CENTER" spacing="10">
                                    <FontAwesomeIconView glyphName="FOLDER_OPEN" size="15" styleClass="btn-icon" />
                                    <Label styleClass="btn-text" text="Choose File" />
                                </HBox>
                            </graphic>
                        </Button>
                        <Button fx:id="removePhotoBtn" managed="false" styleClass="btn-remove-photo"
                                text="✕  Remove Photo" visible="false" />
                    </VBox>

                    <!-- RIGHT: Image preview -->
                    <StackPane fx:id="imagePreviewContainer" styleClass="image-preview-container"
                               GridPane.columnIndex="1">
                        <VBox fx:id="imagePlaceholder" alignment="CENTER" spacing="14"
                              styleClass="image-placeholder">
                            <StackPane maxHeight="72" maxWidth="72" styleClass="placeholder-icon-ring">
                                <FontAwesomeIconView glyphName="IMAGE" size="30" styleClass="placeholder-icon" />
                            </StackPane>
                            <VBox alignment="CENTER" spacing="4">
                                <Label styleClass="placeholder-title" text="No Photo Selected" />
                                <Label styleClass="placeholder-hint" text="Preview will appear here"
                                       textAlignment="CENTER" wrapText="true" />
                            </VBox>
                        </VBox>
                        <ImageView fx:id="damagePhotoView" fitHeight="200" fitWidth="320"
                                   managed="false" preserveRatio="true" smooth="true" visible="false">
                            <effect>
                                <DropShadow color="rgba(0,0,0,0.4)" offsetX="0" offsetY="2" radius="12" spread="0.0" />
                            </effect>
                        </ImageView>
                        <StackPane fx:id="previewBadge" managed="false" styleClass="preview-badge"
                                   visible="false" StackPane.alignment="BOTTOM_RIGHT">
                            <padding><Insets bottom="10" right="10" /></padding>
                            <HBox alignment="CENTER" spacing="6" styleClass="preview-badge-inner">
                                <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="12" styleClass="preview-badge-icon" />
                                <Label styleClass="preview-badge-text" text="Photo Attached" />
                            </HBox>
                        </StackPane>
                    </StackPane>
                </GridPane>
            </VBox>

            <Separator />

            <!-- ── SECTION 4: ADDITIONAL INFORMATION ── -->
            <VBox spacing="18" styleClass="form-section">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="STICKY_NOTE" size="18" styleClass="section-icon" />
                    <Label styleClass="section-title" text="Additional Information" />
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Damage Assessment Notes" />
                    <VBox styleClass="flat-input-textarea">
                        <TextArea fx:id="notesFld" prefRowCount="4"
                                  promptText="Enter detailed notes about the damage assessment (optional)"
                                  styleClass="field-textarea" wrapText="true" />
                    </VBox>
                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- ==================== FOOTER ==================== -->
    <HBox alignment="CENTER_RIGHT" spacing="14" styleClass="dialog-footer">
        <padding><Insets bottom="20" left="24" right="24" top="20" /></padding>
        <Button fx:id="saveBtn" styleClass="btn-primary">
            <graphic>
                <HBox alignment="CENTER" spacing="10">
                    <FontAwesomeIconView glyphName="SAVE" size="16" styleClass="btn-icon" />
                    <Label styleClass="btn-text" text="Save Damage Assessment" />
                </HBox>
            </graphic>
        </Button>
    </HBox>

</VBox>
