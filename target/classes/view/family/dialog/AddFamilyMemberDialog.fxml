<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.*?>
<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    DROPDOWN STRATEGY — identical to the Dashboard map search:

    The beneficiary search is a VBox wrapper (fx:id="searchBoxWrap") that holds:
      1. The TextField  — always visible/managed
      2. The ListView   — managed="false" visible="false" by default

    The controller shows/hides the ListView with setVisible()+setManaged() only,
    exactly like DashboardController.showInlineDropdown() / hideInlineDropdown().

    WHY THIS WORKS (and the AnchorPane overlay did not):
      • The ListView is INSIDE the ScrollPane's content VBox, so it scrolls with
        the form and is never clipped by an outer rounded-corner border-radius.
      • managed=false means it does NOT affect the flow layout of the VBox while
        hidden — it pops into existence below the TextField when shown.
      • No sceneToLocal() math, no applyCss() bootstrapping, no viewOrder hacks.
      • The ScrollPane content expands to accommodate the open list naturally.

    The root is back to a plain VBox (the visible dialog card) — no AnchorPane
    wrapper needed since we are no longer absolutely positioning anything.
-->
<VBox fx:id="root" prefHeight="800.0" prefWidth="1100.0" styleClass="dialog-root"
      stylesheets="@/styles/family/dialog/addfamilydialog.css"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ionres.respondph.familymembers.dialogs_controller.AddFamilyController">

    <!-- ==================== HEADER ==================== -->
    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="dialog-header">
        <padding><Insets bottom="18" left="24" right="24" top="18" /></padding>
        <FontAwesomeIconView glyphName="USERS" size="22" styleClass="header-icon" />
        <VBox spacing="2">
            <Label styleClass="dialog-title" text="Add Family Member" />
            <Label styleClass="dialog-subtitle" text="Fields marked with * are required. Add a family member to an existing beneficiary." />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="exitBtn" styleClass="dialog-close">
            <graphic>
                <HBox alignment="CENTER" spacing="8">
                    <FontAwesomeIconView glyphName="TIMES" size="14" styleClass="close-icon" />
                </HBox>
            </graphic>
        </Button>
    </HBox>

    <!-- ==================== SCROLLABLE BODY ==================== -->
    <ScrollPane fitToWidth="true" styleClass="dialog-scroll" VBox.vgrow="ALWAYS">
        <VBox spacing="24" styleClass="dialog-body">
            <padding><Insets bottom="24" left="24" right="24" top="20" /></padding>

            <!-- ── SECTION 1: SELECT BENEFICIARY ── -->
            <VBox spacing="18" styleClass="form-section">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="SEARCH" size="18" styleClass="section-icon" />
                    <Label styleClass="section-title" text="Select Beneficiary" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="section-subtitle" text="Step 1 of 4" />
                </HBox>

                <VBox spacing="6" styleClass="info-box">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <FontAwesomeIconView glyphName="INFO_CIRCLE" size="14" styleClass="info-icon" />
                        <Label styleClass="info-title" text="Beneficiary Selection" />
                    </HBox>
                    <Label styleClass="info-text" text="• Search and select the beneficiary to whom this family member belongs" />
                    <Label styleClass="info-text" text="• You can search by typing the beneficiary's name or ID" />
                </VBox>

                <VBox spacing="8">
                    <Label styleClass="field-label" text="Search Beneficiary Name *" />

                    <!--
                        searchBoxWrap: mirrors dashboard's searchBoxWrap exactly.
                        spacing="0" so the TextField and ListView are flush against
                        each other with no gap — giving the seamless joined look.
                        pickOnBounds="false" so clicks pass through the transparent
                        area around the TextField when the list is hidden.
                    -->
                    <VBox fx:id="searchBoxWrap" spacing="0" pickOnBounds="false">

                        <!-- The input row — always visible -->
                        <HBox fx:id="beneficiaryInputRow"
                              alignment="CENTER_LEFT" spacing="10"
                              styleClass="flat-input,beneficiary-search-input">
                            <FontAwesomeIconView glyphName="USER" size="14" styleClass="field-icon" />
                            <TextField fx:id="beneficiaryNameFld"
                                       promptText="Type to search beneficiary name or ID"
                                       styleClass="field-input"
                                       HBox.hgrow="ALWAYS" />
                            <FontAwesomeIconView fx:id="beneficiaryCaretIcon"
                                                 glyphName="CHEVRON_DOWN" size="11"
                                                 styleClass="beneficiary-caret-icon" />
                        </HBox>

                        <!--
                            The dropdown list — hidden by default.
                            managed="false" means it takes no vertical space when hidden,
                            so it never pushes the form sections below it downward.
                            When shown (managed=true + visible=true), it expands into
                            the flow below the input row, exactly as in the dashboard.
                        -->
                        <ListView fx:id="beneficiarySearchList"
                                  styleClass="search-popup-list"
                                  managed="false"
                                  visible="false" />
                    </VBox>
                </VBox>
            </VBox>

            <Separator />

            <!-- ── SECTION 2: FAMILY MEMBER INFORMATION ── -->
            <VBox spacing="18" styleClass="form-section">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="USER" size="18" styleClass="section-icon" />
                    <Label styleClass="section-title" text="Family Member Information" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="section-subtitle" text="Step 2 of 4" />
                </HBox>

                <GridPane hgap="16" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="40" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="30" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="30" />
                    </columnConstraints>
                    <VBox spacing="8" GridPane.columnIndex="0">
                        <Label styleClass="field-label" text="First Name *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="USER" size="14" styleClass="field-icon" />
                            <TextField fx:id="firstNameFld" promptText="Enter first name" styleClass="field-input" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                    <VBox spacing="8" GridPane.columnIndex="1">
                        <Label styleClass="field-label" text="Middle Name" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="USER" size="14" styleClass="field-icon" />
                            <TextField fx:id="middleNameFld" promptText="Middle name" styleClass="field-input" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                    <VBox spacing="8" GridPane.columnIndex="2">
                        <Label styleClass="field-label" text="Last Name *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="USER" size="14" styleClass="field-icon" />
                            <TextField fx:id="lastNameFld" promptText="Last name" styleClass="field-input" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                    <rowConstraints><RowConstraints /></rowConstraints>
                </GridPane>

                <GridPane hgap="16" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                    </columnConstraints>
                    <VBox spacing="8" GridPane.columnIndex="0">
                        <Label styleClass="field-label" text="Date of Birth *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="CALENDAR" size="14" styleClass="field-icon" />
                            <DatePicker fx:id="birthDatePicker" promptText="Month/Day/Year" styleClass="field-date" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                    <VBox spacing="8" GridPane.columnIndex="1">
                        <Label styleClass="field-label" text="Gender *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="VENUS_MARS" size="14" styleClass="field-icon" />
                            <ComboBox fx:id="genderSelection" maxWidth="1.7976931348623157E308" promptText="Select gender" styleClass="field-combo" HBox.hgrow="ALWAYS">
                                <items><FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Male" /><String fx:value="Female" />
                                </FXCollections></items>
                            </ComboBox>
                        </HBox>
                    </VBox>
                    <VBox spacing="8" GridPane.columnIndex="2">
                        <Label styleClass="field-label" text="Marital Status *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="HEART" size="14" styleClass="field-icon" />
                            <ComboBox fx:id="maritalStatusSelection" maxWidth="1.7976931348623157E308" promptText="Select status" styleClass="field-combo" HBox.hgrow="ALWAYS">
                                <items><FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Single" /><String fx:value="Married" />
                                    <String fx:value="Widowed" /><String fx:value="Separated" />
                                </FXCollections></items>
                            </ComboBox>
                        </HBox>
                    </VBox>
                    <VBox spacing="8" GridPane.columnIndex="3">
                        <Label styleClass="field-label" text="Relationship *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="LINK" size="14" styleClass="field-icon" />
                            <ComboBox fx:id="relationshipSelection" maxWidth="1.7976931348623157E308" promptText="Select relationship" styleClass="field-combo" HBox.hgrow="ALWAYS">
                                <items><FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Son" /><String fx:value="Daughter" />
                                    <String fx:value="Grandchild" /><String fx:value="Niece" />
                                    <String fx:value="Nephew" /><String fx:value="Brother" />
                                    <String fx:value="Brother in Law" /><String fx:value="Sister in Law" />
                                    <String fx:value="Sister" /><String fx:value="Uncle" />
                                    <String fx:value="Auntie" /><String fx:value="Wife" />
                                    <String fx:value="Husband" /><String fx:value="Common Law" />
                                    <String fx:value="Father" /><String fx:value="Father in Law" />
                                    <String fx:value="Mother" /><String fx:value="Mother in Law" />
                                    <String fx:value="Step Sister" /><String fx:value="Step Brother" />
                                    <String fx:value="Step Father" /><String fx:value="Step Mother" />
                                    <String fx:value="Step GrandMother" /><String fx:value="Step GrandFather" />
                                    <String fx:value="Grandmother" /><String fx:value="Grandfather" />
                                    <String fx:value="Great GrandFather" /><String fx:value="Great GrandMother" />
                                    <String fx:value="Relative" /><String fx:value="Other relative" />
                                </FXCollections></items>
                            </ComboBox>
                        </HBox>
                    </VBox>
                    <rowConstraints><RowConstraints /></rowConstraints>
                </GridPane>
            </VBox>

            <Separator />

            <!-- ── SECTION 3: HEALTH INFORMATION ── -->
            <VBox spacing="18" styleClass="form-section">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="MEDKIT" size="18" styleClass="section-icon" />
                    <Label styleClass="section-title" text="Health Information" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="section-subtitle" text="Step 3 of 4" />
                </HBox>
                <GridPane hgap="16" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                    </columnConstraints>
                    <VBox spacing="8" GridPane.columnIndex="0">
                        <Label styleClass="field-label" text="Disability Type *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="WHEELCHAIR" size="14" styleClass="field-icon" />
                            <ComboBox fx:id="disabilityTypeSelection" maxWidth="1.7976931348623157E308" promptText="Select disability type" styleClass="field-combo" HBox.hgrow="ALWAYS">
                                <items><FXCollections fx:factory="observableArrayList">
                                    <String fx:value="None" /><String fx:value="Physical" />
                                    <String fx:value="Visual" /><String fx:value="Hearing" />
                                    <String fx:value="Speech" /><String fx:value="Intellectual" />
                                    <String fx:value="Mental/Psychosocial" />
                                    <String fx:value="Due to Chronic Illness" />
                                    <String fx:value="Multiple Disabilities" />
                                </FXCollections></items>
                            </ComboBox>
                        </HBox>
                    </VBox>
                    <VBox spacing="8" GridPane.columnIndex="1">
                        <Label styleClass="field-label" text="Health Condition *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="HEARTBEAT" size="14" styleClass="field-icon" />
                            <ComboBox fx:id="healthConditionSelection" maxWidth="1.7976931348623157E308" promptText="Select health condition" styleClass="field-combo" HBox.hgrow="ALWAYS">
                                <items><FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Healthy" /><String fx:value="Temporarily ill" />
                                    <String fx:value="Chronically ill" /><String fx:value="Immunocompromised" />
                                    <String fx:value="Terminally ill" />
                                    <String fx:value="With History of Hospitalization/ Long-term Medical Equipment Dependency" />
                                </FXCollections></items>
                            </ComboBox>
                        </HBox>
                    </VBox>
                    <rowConstraints><RowConstraints /></rowConstraints>
                </GridPane>
            </VBox>

            <Separator />

            <!-- ── SECTION 4: EDUCATION &amp; EMPLOYMENT ── -->
            <VBox spacing="18" styleClass="form-section">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="section-header">
                    <FontAwesomeIconView glyphName="LINE_CHART" size="18" styleClass="section-icon" />
                    <Label styleClass="section-title" text="Education and Employment" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="section-subtitle" text="Step 4 of 4" />
                </HBox>
                <GridPane hgap="16" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                    </columnConstraints>
                    <VBox spacing="8" GridPane.columnIndex="0">
                        <Label styleClass="field-label" text="Employment Status *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="BRIEFCASE" size="14" styleClass="field-icon" />
                            <ComboBox fx:id="employmentStatusSelection" maxWidth="1.7976931348623157E308" promptText="Select employment status" styleClass="field-combo" HBox.hgrow="ALWAYS">
                                <items><FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Regular full-time employment" />
                                    <String fx:value="Self-employed with stable income" />
                                    <String fx:value="Self-employed with unstable income" />
                                    <String fx:value="Informal or irregular employment" />
                                    <String fx:value="Unemployed" />
                                </FXCollections></items>
                            </ComboBox>
                        </HBox>
                    </VBox>
                    <VBox spacing="8" GridPane.columnIndex="1">
                        <Label styleClass="field-label" text="Highest Education Level *" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="flat-input">
                            <FontAwesomeIconView glyphName="GRADUATION_CAP" size="14" styleClass="field-icon" />
                            <ComboBox fx:id="educationLevelSelection" maxWidth="1.7976931348623157E308" promptText="Select education level" styleClass="field-combo" HBox.hgrow="ALWAYS">
                                <items><FXCollections fx:factory="observableArrayList">
                                    <String fx:value="No Formal Education" />
                                    <String fx:value="Elementary" /><String fx:value="High School" />
                                    <String fx:value="Vocational or technical training" />
                                    <String fx:value="College or university level" />
                                    <String fx:value="Graduate education" />
                                </FXCollections></items>
                            </ComboBox>
                        </HBox>
                    </VBox>
                    <rowConstraints><RowConstraints /></rowConstraints>
                </GridPane>

                <VBox spacing="8">
                    <Label styleClass="field-label" text="Additional Notes" />
                    <VBox styleClass="flat-input-textarea">
                        <TextArea fx:id="notesFld" prefRowCount="4"
                                  promptText="Enter any additional notes about this family member (optional)"
                                  styleClass="field-textarea" wrapText="true" />
                    </VBox>
                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- ==================== FOOTER ==================== -->
    <HBox alignment="CENTER_RIGHT" spacing="14" styleClass="dialog-footer">
        <padding><Insets bottom="20" left="24" right="24" top="20" /></padding>
        <Button fx:id="saveBtn" styleClass="btn-primary">
            <graphic>
                <HBox alignment="CENTER" spacing="10">
                    <FontAwesomeIconView glyphName="SAVE" size="16" styleClass="btn-icon" />
                    <Label styleClass="btn-text" text="Save Family Member" />
                </HBox>
            </graphic>
        </Button>
    </HBox>

</VBox>
